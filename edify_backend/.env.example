# Copy to .env and fill in values for local dev, or set in your deploy env.
# Anything not set falls back to the dev defaults baked into edify_core/settings.py.
# .env files are gitignored; .env.example is committed.

# REQUIRED in production (DEBUG=false). Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# "true" for local dev (the default if unset), "false" for production.
DJANGO_DEBUG=true

# Comma-separated hostnames allowed to serve the app. Required when DEBUG=false.
# In dev, if unset, falls back to localhost/127.0.0.1/testserver.
DJANGO_ALLOWED_HOSTS=

# Comma-separated CORS origins for the frontend. In dev (DEBUG=true) all origins
# are allowed; in production only these will be.
DJANGO_CORS_ORIGINS=

# Celery / Redis — only needed if you're running actual async tasks locally.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Seed script password override (used by apps/seeders/base_factory.py).
SEED_PASSWORD=DemoAccount2025!

# --- Email verification (Phase 4.2) ---
# Off by default so local dev and automated tests can log in without activation.
# Flip to "true" in production so JWT issuance rejects unverified accounts.
REQUIRE_EMAIL_VERIFICATION=false

# Email backend: console in dev (activation link prints to stdout), SMTP in prod.
DJANGO_EMAIL_BACKEND=
DJANGO_EMAIL_HOST=localhost
DJANGO_EMAIL_PORT=25
DJANGO_EMAIL_USER=
DJANGO_EMAIL_PASSWORD=
DJANGO_EMAIL_USE_TLS=true
DJANGO_FROM_EMAIL=no-reply@maple.edify

# Base URL of the frontend for building activation links in emails.
FRONTEND_BASE_URL=http://localhost:5173
