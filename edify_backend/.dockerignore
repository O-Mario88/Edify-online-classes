# Backend Dockerfile build context ignore.
.git
.github
venv
.venv
__pycache__
**/__pycache__
*.pyc
.pytest_cache
.mypy_cache
.ruff_cache
*.log
backend.log
# Local dev DB — we want a fresh DB inside the container
db.sqlite3
db.sqlite3-journal
# Collected static is rebuilt inside the image
staticfiles
# User-uploaded media is a volume; don't bake any into the image
media
# Temp
tmp
