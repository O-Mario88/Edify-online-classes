                  "posts": [
                    {
                      "id": "post-s2-math-1",
                      "title": "Factoring quadratic expressions",
                      "content": "I need help with factoring expressions like x² + 5x + 6. What method should I use?",
                      "authorId": "student-1",
                      "authorName": "Grace Nakato",
                      "authorRole": "student",
                      "createdAt": "2025-06-23T16:00:00Z",
                      "updatedAt": "2025-06-23T16:00:00Z",
                      "replies": [
                        {
                          "id": "reply-s2-math-1-1",
                          "content": "For x² + 5x + 6, look for two numbers that multiply to 6 and add to 5. Those are 2 and 3, so the factored form is (x + 2)(x + 3).",
                          "authorId": "teacher-math-1",
                          "authorName": "Dr. Sarah Nakamya",
                          "authorRole": "teacher",
                          "createdAt": "2025-06-23T17:15:00Z",
                          "likes": 15,
                          "isTeacherApproved": true
                        }
                      ],
                      "tags": ["mathematics", "quadratics", "factoring", "senior-2"],
                      "views": 89,
                      "likes": 24,
                      "isPinned": true,
                      "isSolved": true
                    }
                  ]
                }
              ]
            }
          ]
