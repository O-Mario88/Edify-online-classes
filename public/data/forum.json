                  "posts": [
                    {
                      "id": "post-s1-math-1",
                      "title": "Help with solving linear equations",
                      "content": "I'm having trouble understanding how to solve equations like 2x + 5 = 13. Can someone explain the steps clearly?",
                      "authorId": "student-2",
                      "authorName": "David Musoke",
                      "authorRole": "student",
                      "createdAt": "2025-06-25T10:30:00Z",
                      "updatedAt": "2025-06-25T10:30:00Z",
                      "replies": [
                        {
                          "id": "reply-s1-math-1-1",
                          "content": "To solve 2x + 5 = 13, first subtract 5 from both sides: 2x = 8. Then divide both sides by 2: x = 4. Always remember to do the same operation on both sides!",
                          "authorId": "teacher-math-1",
                          "authorName": "Dr. Sarah Nakamya",
                          "authorRole": "teacher",
                          "createdAt": "2025-06-25T11:15:00Z",
                          "likes": 12,
                          "isTeacherApproved": true
                        },
                        {
                          "id": "reply-s1-math-1-2",
                          "content": "Thank you! That makes it much clearer. So I always work backwards from the operations?",
                          "authorId": "student-2",
                          "authorName": "David Musoke",
                          "authorRole": "student",
                          "createdAt": "2025-06-25T11:45:00Z",
                          "likes": 3
                        }
                      ],
                      "tags": ["algebra", "linear-equations", "senior-1", "mathematics"],
                      "views": 67,
                      "likes": 18,
                      "isPinned": false,
                      "isSolved": true
                    }
                  ]
                }
              ]
            },
            {
              "id": "cat-senior-1-physics",
              "name": "Physics",
              "level": "subject",
              "subcategories": [
                {
                  "id": "cat-senior-1-physics-mechanics",
                  "name": "Basic Mechanics",
                  "level": "topic",
                  "posts": [
                    {
                      "id": "post-s1-phy-1",
                      "title": "Understanding types of motion",
                      "content": "What's the difference between linear motion and circular motion? I'm confused about the examples.",
                      "authorId": "student-2",
                      "authorName": "David Musoke",
                      "authorRole": "student",
                      "createdAt": "2025-06-24T14:20:00Z",
                      "updatedAt": "2025-06-24T14:20:00Z",
                      "replies": [
                        {
                          "id": "reply-s1-phy-1-1",
                          "content": "Linear motion is movement in a straight line (like a car on a straight road), while circular motion is movement in a circle (like a wheel spinning). Both are common in everyday life!",
                          "authorId": "teacher-phy-1",
                          "authorName": "Mr. Paul Wasswa",
                          "authorRole": "teacher",
                          "createdAt": "2025-06-24T15:30:00Z",
                          "likes": 8,
                          "isTeacherApproved": true
                        }
                      ],
                      "tags": ["physics", "mechanics", "motion", "senior-1"],
                      "views": 45,
                      "likes": 12,
                      "isPinned": false,
                      "isSolved": true
                    }
                  ]
                }
              ]
            }
          ]
