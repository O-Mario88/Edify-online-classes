      "id": "post-general-2",
      "title": "Study Tips for Uganda Secondary Students",
      "content": "What are your best study tips for success in O'level and A'level? Share your strategies that have worked well!",
      "authorId": "student-3",
      "authorName": "Sarah Namuli",
      "authorRole": "student",
      "createdAt": "2025-06-10T16:00:00Z",
      "updatedAt": "2025-06-10T16:00:00Z",
      "replies": [
        {
          "id": "reply-general-2-1",
          "content": "Create a study timetable, practice past papers regularly, and form study groups. Also, don't neglect your health - eat well and get enough sleep!",
          "authorId": "teacher-gp",
          "authorName": "Dr. Michael Ssebunya",
          "authorRole": "teacher",
          "createdAt": "2025-06-10T17:30:00Z",
          "likes": 45,
          "isTeacherApproved": true
        },
        {
          "id": "reply-general-2-2",
          "content": "I use the Pomodoro technique - 25 minutes focused study, 5 minutes break. It really helps with concentration!",
          "authorId": "student-4",
          "authorName": "John Kiwanuka",
          "authorRole": "student",
          "createdAt": "2025-06-10T18:00:00Z",
          "likes": 29
        }
      ],
