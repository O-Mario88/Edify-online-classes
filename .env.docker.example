# Copy to `.env` before the first `docker compose up`.
# Anything starred (*) is required for prod-ish mode. The rest have sane defaults.

# * required. Generate once with:
#   python -c "from secrets import token_urlsafe; print(token_urlsafe(50))"
DJANGO_SECRET_KEY=

# Prod-ish by default. Set true to run Docker with DEBUG=true.
DJANGO_DEBUG=false

# Comma-separated. Must include every hostname the service will be reached at.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,frontend

# Comma-separated prod CORS origins (leave blank in dev).
DJANGO_CORS_ORIGINS=

# Exposed ports on the host.
BACKEND_PORT=8000
FRONTEND_PORT=8080

# Postgres.
POSTGRES_DB=maple
POSTGRES_USER=maple
POSTGRES_PASSWORD=maple_dev

# Email. Leave DJANGO_EMAIL_BACKEND unset to use console backend (logs to stdout).
# For real email, set it to django.core.mail.backends.smtp.EmailBackend and fill
# in HOST/PORT/USER/PASSWORD/USE_TLS for Postmark / SendGrid / Resend / etc.
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_EMAIL_HOST=
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_USER=
DJANGO_EMAIL_PASSWORD=
DJANGO_EMAIL_USE_TLS=true
DJANGO_FROM_EMAIL=no-reply@maple.edify

# Gate login on verified email? Default off so first-boot demos work without SMTP.
REQUIRE_EMAIL_VERIFICATION=false

# Public URL where activation links land. Must match a routable frontend.
FRONTEND_BASE_URL=http://localhost:8080

# Seed demo accounts use this password. Ignored if you don't run the seeder.
SEED_PASSWORD=DemoAccount2025!

# Leave blank so the frontend hits /api on the same origin (nginx proxies).
# Set to a full URL only if the frontend will reach the backend cross-origin.
VITE_API_BASE_URL=
